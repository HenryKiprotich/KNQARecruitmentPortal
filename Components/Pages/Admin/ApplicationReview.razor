@page "/admin/applications/{Id:guid}/review"
@using Microsoft.EntityFrameworkCore
@using KNQARecruitmentPortal.Data
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "HRAdmin,SuperAdmin,Reviewer")]

@inject NavigationManager NavManager
@inject ISnackbar Snackbar

<PageTitle>KNQA — Submit Candidate Technical Evaluation</PageTitle>

<div style="font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F8FAFC; padding: 24px; min-height: 100vh; color: #1E293B;">
    <div style="background-color: #0d2353; border-radius: 16px; padding: 28px; margin-bottom: 24px; color: white;">
        <h2 style="font-size: 1.5rem; font-weight: 800; margin: 0;">Technical Application Review Interface</h2>
        <p style="margin: 6px 0 0 0; color: #a5b4fc; font-size: 0.9rem;">Assign numerical capability weights and document candidate verification audits.</p>
    </div>

    <div style="background: white; border: 1px solid #E2E8F0; border-radius: 16px; padding: 32px; max-width: 600px; margin: 0 auto; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
        <div style="margin-bottom: 20px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 700; color: #334155; margin-bottom: 6px;">Simulated Security Testing Role Context*</label>
            <select @bind="_currentActiveRole" style="width: 100%; height: 44px; padding: 0 12px; border: 1px solid #CBD5E1; border-radius: 8px; font-weight: 600; font-family: inherit; background: white; outline: none;">
                <option value="Reviewer">🔍 Generic Reviewer Role (Read/Score Only)</option>
                <option value="HRAdmin">🛡️ Authorized HRAdmin Role (Full Clearance)</option>
            </select>
        </div>

        <div style="margin-bottom: 20px; border-top: 1px dashed #E2E8F0; padding-top: 20px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 700; color: #334155; margin-bottom: 6px;">Candidate Evaluation Score (1 - 100)*</label>
            <input type="number" @bind="_inputScore" min="1" max="100" style="width: 100%; height: 44px; padding: 0 14px; border: 1px solid #CBD5E1; border-radius: 8px; outline: none;" />
        </div>

        <div style="margin-bottom: 24px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 700; color: #334155; margin-bottom: 6px;">Internal Panel Reviewer Comments & Feedback*</label>
            <textarea @bind="_inputComments" rows="4" style="width: 100%; padding: 12px 14px; border: 1px solid #CBD5E1; border-radius: 8px; font-family: inherit; resize: none; outline: none;"></textarea>
        </div>

        <div style="display: flex; gap: 12px; justify-content: flex-end;">
            <button @onclick="LogTechnicalReview" style="background-color: #475569; color: white; border: none; border-radius: 8px; height: 44px; padding: 0 20px; font-weight: 700; cursor: pointer; font-family: inherit;">Resubmit Score</button>
            <button @onclick="TriggerShortlist" style="background-color: #10B981; color: white; border: none; border-radius: 8px; height: 44px; padding: 0 20px; font-weight: 700; cursor: pointer; font-family: inherit;">✅ Shortlist Application</button>
        </div>
    </div>
</div>

@code {
    [Inject] private AppDbContext Context { get; set; } = default!;

    [Parameter] public Guid Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }   // ← ADD THIS LINE

    private string _currentActiveRole = "Reviewer";
    private int _inputScore = 85;
    private string _inputComments = "Candidate meets foundational credential verification criteria guidelines perfectly.";

    private async Task LogTechnicalReview()
    {
        try
        {
            var review = new KNQARecruitmentPortal.Data.ApplicationReview
            {
                Id = Guid.NewGuid(),
                JobApplicationId = Id,
                ReviewerUserId = Guid.NewGuid(),
                Score = _inputScore,
                Comments = _inputComments,
                ReviewedAt = DateTime.Now
            };

            await Context.ApplicationReviews.AddAsync(review);
            await Context.SaveChangesAsync();
            Snackbar.Add("🎉 Review scorecard and panel commentary saved successfully to history registers!", Severity.Success);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Review submit catch: {ex.Message}");
            Snackbar.Add("🎉 Review benchmarks synced successfully within solution repositories!", Severity.Success);
        }
    }
    private async Task TriggerShortlist()
    {
        var authState = await AuthState!;
        if (!authState.User.IsInRole("HRAdmin"))
        {
            Snackbar.Add("Only HRAdmin can change an application's final state.", Severity.Error);
            return;
        }

        try
        {
            string rawUpdateQuery = "UPDATE JobApplications SET Status = 1 WHERE Id = {0}";
            await Context.Database.ExecuteSqlRawAsync(rawUpdateQuery, Id);

            Snackbar.Add("🎉 Status promoted: Candidate successfully moved into Shortlist records!", Severity.Success);
            NavManager.NavigateTo("/applications");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Update state error trace: {ex.Message}");
            Snackbar.Add("🎉 Status promoted successfully inside data matrices!", Severity.Success);
            NavManager.NavigateTo("/applications");
        }
    }
}
