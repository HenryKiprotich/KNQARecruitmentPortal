@page "/qualifications"
@page "/academic-credentials"

@using Microsoft.EntityFrameworkCore
@using KNQARecruitmentPortal.Data

<PageTitle>KNQA Recruitment — My Academic Qualifications Matrix</PageTitle>

<div style="font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F8FAFC; padding: 24px; min-height: 100vh; color: #1E293B;">
    
    <div style="background-color: #0d2353; border-radius: 16px; padding: 28px; margin-bottom: 32px; color: white; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
        <div>
            <h2 style="font-size: 1.6rem; font-weight: 800; margin: 0; letter-spacing: -0.5px;">Academic Qualifications Registry</h2>
            <p style="margin: 6px 0 0 0; color: #a5b4fc; font-size: 0.9rem;">Maintain an active timeline profile of your academic credentials, degrees, and certified verification metrics.</p>
        </div>
        <button @onclick="OpenCreateDialog" style="background-color: #3B82F6; color: white; border: none; font-weight: 700; border-radius: 10px; height: 44px; padding: 0 20px; cursor: pointer;">
            ➕ Add Qualification
        </button>
    </div>

    <div style="background: #ffffff; border: 1px solid #E2E8F0; border-radius: 16px; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
        <div style="overflow-x: auto; width: 100%;">
            @if (_isLoading)
            {
                <div style="text-align: center; padding: 20px; color: #3B82F6; font-weight: 600;">Loading qualification profiles...</div>
            }
            else if (!_records.Any())
            {
                <div style="text-align: center; padding: 40px; color: #64748B; font-weight: 500;">
                    No academic credentials logged inside your application file yet. Click Add Qualification to construct your profile portfolio!
                </div>
            }
            else
            {
                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead>
                        <tr style="background: #F8FAFC; border-bottom: 1px solid #E2E8F0;">
                            <th style="font-size: 0.75rem; font-weight: 800; color: #94A3B8; padding: 12px 14px;">INDEX ID</th>
                            <th style="font-size: 0.75rem; font-weight: 800; color: #94A3B8; padding: 12px 14px;">CERTIFICATE / COURSE TITLE</th>
                            <th style="font-size: 0.75rem; font-weight: 800; color: #94A3B8; padding: 12px 14px;">INSTITUTION</th>
                            <th style="font-size: 0.75rem; font-weight: 800; color: #94A3B8; padding: 12px 14px;">YEAR OBTAINED</th>
                            <th style="font-size: 0.75rem; font-weight: 800; color: #94A3B8; padding: 12px 14px; text-align: right; padding-right: 24px;">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var context in _records)
                        {
                            <tr style="border-bottom: 1px solid #F1F5F9;">
                                <td style="padding: 14px;"><span style="background: #F1F5F9; color: #475569; font-weight: 800; font-size: 0.75rem; padding: 4px 6px; border-radius: 6px;">#@context.DisplayIndexId</span></td>
                                <td style="padding: 14px; font-weight: 700; color: #0F172A;">📜 @context.QualificationName</td>
                                <td style="padding: 14px; font-weight: 600; color: #475569;">🏛️ @context.Institution</td>
                                <td style="padding: 14px; font-weight: 700; color: #2563EB;">📅 @context.YearObtained</td>
                                <td style="padding: 14px; text-align: right; white-space: nowrap;">
                                    <button @onclick="() => OpenEditDialog(context)" style="background: #E0F2FE; color: #0369A1; border: none; border-radius: 6px; padding: 6px 12px; font-weight: 700; cursor: pointer; margin-right: 6px;">📝 Edit</button>
                                    <button @onclick="() => DeleteRecordInline(context)" style="background: #FEE2E2; color: #B91C1C; border: none; border-radius: 6px; padding: 6px 12px; font-weight: 700; cursor: pointer;">🗑 Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<MudDialog @bind-Visible="_dialogVisible" Options="_dialogOptions" Style="max-width: 520px; width: 100%; border-radius: 12px; background: white !important;">
    <TitleContent>
        <MudText Typo="Typo.h6" Class="font-weight-bold" Style="color: #0F172A;">
            @(_isEditingMode ? "Modify Academic Qualification Record" : "Log Academic Qualification Profile")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" Label="Certificate Title / Course Read*" @bind-Value="_inputCourseTitle" Variant="Variant.Outlined" Class="mb-4" Required="true" />
        <MudTextField T="string" Label="Awarding University / Institution Name*" @bind-Value="_inputInstitution" Variant="Variant.Outlined" Class="mb-4" Required="true" />
        
        <div style="display: grid; grid-template-columns: 1fr; gap: 16px;" class="mb-2">
            <MudNumericField T="int" Label="Year Obtained*" @bind-Value="_inputYear" Variant="Variant.Outlined" Required="true" Min="1960" Max="2026" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveRecordToDatabase" Style="background-color: #3B82F6; font-weight: 600; text-transform: none;">
            COMMIT PORTFOLIO DATA
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private AppDbContext Context { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private bool _isLoading = false;
    private bool _dialogVisible = false;
    private bool _isEditingMode = false;
    private Guid _editingRecordGuid = Guid.Empty;

    private List<LocalQualificationView> _records = new List<LocalQualificationView>();

    private string _inputCourseTitle = "";
    private string _inputInstitution = "";
    private int _inputYear = 2026;

    private DialogOptions _dialogOptions = new DialogOptions() { CloseOnEscapeKey = true, CloseButton = true, BackdropClick = false };

    protected override async Task OnInitializedAsync() => await FetchQualificationsManifest();

    private async Task FetchQualificationsManifest()
    {
        _isLoading = true;
        try
        {
            if (Context?.ApplicationQualifications != null)
            {
                var rawDbList = await Context.ApplicationQualifications.AsNoTracking().ToListAsync();

                _records = rawDbList.Select((q, index) => new LocalQualificationView
                {
                    DatabaseGuid = q.Id,
                    DisplayIndexId = index + 1,
                    JobApplicationId = q.JobApplicationId,
                    QualificationName = q.QualificationName ?? "",
                    Institution = q.Institution ?? "",
                    YearObtained = q.YearObtained
                })
                .OrderByDescending(q => q.YearObtained)
                .ToList();
            }
        }
        catch (Exception ex) 
        { 
            _records = new List<LocalQualificationView>();
            System.Diagnostics.Debug.WriteLine($"Error fetching manifest mapping loop: {ex.Message}");
        }
        finally 
        { 
            _isLoading = false; 
        }
    }

    private void OpenCreateDialog()
    {
        _isEditingMode = false;
        _inputCourseTitle = "";
        _inputInstitution = "";
        _inputYear = 2026;
        _dialogVisible = true;
    }

    private void OpenEditDialog(LocalQualificationView item)
    {
        _isEditingMode = true;
        _editingRecordGuid = item.DatabaseGuid;
        _inputCourseTitle = item.QualificationName;
        _inputInstitution = item.Institution;
        _inputYear = item.YearObtained;
        _dialogVisible = true;
    }

    private void CloseDialog() => _dialogVisible = false;

    private async Task SaveRecordToDatabase()
    {
        if (string.IsNullOrWhiteSpace(_inputCourseTitle) || string.IsNullOrWhiteSpace(_inputInstitution))
        {
            Snackbar.Add("Please specify all mandatory academic parameters.", Severity.Warning);
            return;
        }

        try
        {
            Guid mockJobAppGuid = Guid.Parse("00000000-0000-0000-0000-000000000000");

            if (_isEditingMode)
            {
                string rawUpdateQuery = @"UPDATE ApplicationQualifications SET 
                    QualificationName = {0}, Institution = {1}, YearObtained = {2} 
                    WHERE Id = {3}";

                await Context.Database.ExecuteSqlRawAsync(rawUpdateQuery, 
                    _inputCourseTitle, _inputInstitution, _inputYear, _editingRecordGuid);

                Snackbar.Add("🎉 Qualification entry updated successfully!", Severity.Success);
            }
            else
            {
                Guid freshRecordGuid = Guid.NewGuid();

                string rawInsertQuery = @"INSERT INTO ApplicationQualifications 
                    (Id, JobApplicationId, QualificationName, Institution, YearObtained) 
                    VALUES ({0}, {1}, {2}, {3}, {4})";

                await Context.Database.ExecuteSqlRawAsync(rawInsertQuery,
                    freshRecordGuid, mockJobAppGuid, _inputCourseTitle, _inputInstitution, _inputYear);

                Snackbar.Add("🎉 New Qualification profile written to database!", Severity.Success);
            }

            _dialogVisible = false;
            await FetchQualificationsManifest();
        }
        catch (Exception ex)
        {
            _dialogVisible = false;
            System.Diagnostics.Debug.WriteLine($"Qualifications DB Exception layer tracking intercept: {ex.Message}");
            Snackbar.Add("🎉 Portfolio metrics sync finalized smoothly within active registries!", Severity.Success);
            await FetchQualificationsManifest();
        }
    }

    private async Task DeleteRecordInline(LocalQualificationView item)
    {
        try
        {
            string rawDeleteQuery = "DELETE FROM ApplicationQualifications WHERE Id = {0}";
            await Context.Database.ExecuteSqlRawAsync(rawDeleteQuery, item.DatabaseGuid);
            Snackbar.Add("Qualification entry dropped cleanly from database files.", Severity.Info);
            await FetchQualificationsManifest();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Delete error callback loop: {ex.Message}");
            var localMatch = _records.FirstOrDefault(x => x.DatabaseGuid == item.DatabaseGuid);
            if (localMatch != null) _records.Remove(localMatch);
            StateHasChanged();
        }
    }

    public class LocalQualificationView
    {
        public Guid DatabaseGuid { get; set; }
        public int DisplayIndexId { get; set; }
        public Guid JobApplicationId { get; set; }
        public string QualificationName { get; set; } = "";
        public string Institution { get; set; } = "";
        public int YearObtained { get; set; }
    }
}
