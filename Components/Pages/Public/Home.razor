@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<PageTitle>KNQA Recruitment Portal — Welcome Home</PageTitle>

<div style="font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F8FAFC; padding: 24px; min-height: 100vh; color: #1E293B;">

    <div style="background: linear-gradient(135deg, #0d2353, #1e40af); border-radius: 16px; padding: 40px; margin-bottom: 32px; color: white; box-shadow: 0 10px 25px rgba(13, 35, 83, 0.15);">
        <h1 style="font-size: 2.2rem; font-weight: 800; margin: 0; letter-spacing: -1px;">Kenya National Qualifications Authority</h1>
        <h3 style="font-size: 1.2rem; font-weight: 500; margin: 8px 0 0 0; color: #93C5FD;">National Recruitment & Credential Verification Portal</h3>
        <p style="margin: 16px 0 0 0; color: #E2E8F0; max-width: 700px; font-size: 0.95rem; line-height: 1.6;">
            Welcome to the centralized KNQA career entry processing engine. Complete your profile, log academic parameters, manage verification attachments, and monitor candidate evaluation tracks cleanly.
        </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-bottom: 32px;">

        <div style="background: white; border: 1px solid #E2E8F0; border-radius: 12px; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
            <div style="font-size: 2rem; margin-bottom: 12px;">🪪</div>
            <h4 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 8px 0; color: #0F172A;">Profile Credentials</h4>
            <p style="font-size: 0.88rem; color: #64748B; margin: 0 0 16px 0; line-height: 1.5;">Maintain your national identification metrics and active mobile contact pipelines.</p>
            <a href="applicantprofile" style="color: #2563EB; font-weight: 700; font-size: 0.85rem; text-decoration: none;">Configure Profile &rarr;</a>
        </div>

        <div style="background: white; border: 1px solid #E2E8F0; border-radius: 12px; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
            <div style="font-size: 2rem; margin-bottom: 12px;">🎓</div>
            <h4 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 8px 0; color: #0F172A;">Qualifications Matrix</h4>
            <p style="font-size: 0.88rem; color: #64748B; margin: 0 0 16px 0; line-height: 1.5;">Log certified degrees, university transcripts, and institutional validation criteria fields.</p>
            <a href="qualifications" style="color: #2563EB; font-weight: 700; font-size: 0.85rem; text-decoration: none;">Manage Education &rarr;</a>
        </div>

        <div style="background: white; border: 1px solid #E2E8F0; border-radius: 12px; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
            <div style="font-size: 2rem; margin-bottom: 12px;">💼</div>
            <h4 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 8px 0; color: #0F172A;">Work Seniority Logs</h4>
            <p style="font-size: 0.88rem; color: #64748B; margin: 0 0 16px 0; line-height: 1.5;">Track historical career timelines and dynamically calculate your aggregate years of service.</p>
            <a href="work-history" style="color: #2563EB; font-weight: 700; font-size: 0.85rem; text-decoration: none;">Inspect History &rarr;</a>
        </div>

    </div>

    <div style="background-color: #EFF6FF; border: 1px solid #BFDBFE; border-radius: 12px; padding: 20px; display: flex; align-items: center; gap: 16px;">
        <div style="font-size: 1.5rem;">🛡️</div>
        <div>
            <h5 style="margin: 0; font-size: 0.95rem; font-weight: 700; color: #1E40AF;">Recruitment Personnel Access Authorization</h5>
            <p style="margin: 4px 0 0 0; font-size: 0.85rem; color: #1E40AF; opacity: 0.85;">
                Authorized corporate panel evaluations can track and modify candidate shortlists inside the <a href="admin-dashboard" style="font-weight: 700; color: #1D4ED8; text-decoration: underline;">Executive Management Console</a>.
            </p>
        </div>
    </div>

</div>
